# Speechmatics API Key (required)
# Create one under "API Keys" at: https://portal.speechmatics.com/
SM_API_KEY=your_speechmatics_api_key_here

# Google Cloud Translation v2 API Key (optional)
# Only needed for the in-app translation feature. Leave blank to skip it.
# Create one at: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your_google_translate_api_key_here

# NOTE: This is a Flutter mobile app — there is no runtime .env on the device.
# Supply these keys EITHER:
#   (a) at runtime, in the app's Settings -> API Access screen (recommended), or
#   (b) at build time, via --dart-define (see the README "Build it yourself").
# Never commit a real .env — only this .env.example with placeholders.
